# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
# Active bot mode (LEAD | HEALTHCARE | PHARMACY)
ACTIVE_BOT=PHARMACY
# Public base URL for WhatsApp media (must be reachable by Meta; use ngrok in local dev)
APP_PUBLIC_URL=http://localhost:5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pharmacy-communication?retryWrites=true&w=majority

# JWT (for future auth implementation)
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info

# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=your-meta-access-token
META_VERIFY_TOKEN=your-webhook-verify-token
META_API_VERSION=v21.0
